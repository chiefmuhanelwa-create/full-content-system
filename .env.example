# Required Environment Variables for Deployment

# Claude AI API Key (Get from: https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase Database Configuration (REQUIRED for persistent data storage)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database
# Use "Connection pooling" string for best performance with Prisma
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection for migrations (non-pooled)
# Used for running database migrations
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-YOUR_REGION.pooler.supabase.com:5432/postgres

# Supabase Client Configuration (Optional - for using Supabase features beyond Prisma)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# NextAuth Configuration (Generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-project-name.vercel.app

# Google OAuth (Get from: https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Owner bypass credentials
OWNER_EMAIL=your_email_here
OWNER_PASSWORD=your_password_here

# MailerLite (Get from: MailerLite → Integrations → API)
MAILERLITE_API_KEY=your_mailerlite_api_key_here

# ManyChat (Get from: ManyChat → Settings → API)
MANYCHAT_API_KEY=your_account_id:your_api_key_here

# Shopify (Get from: Shopify Admin → Apps → Develop apps)
SHOPIFY_SHOP_URL=your_shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_admin_api_token_here

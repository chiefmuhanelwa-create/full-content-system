// Prisma Schema for NOCHILL Viral Script Generator

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Model
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Subscription info
  plan       String    @default("free") // free, pro, agency
  planExpiry DateTime?
  credits    Int       @default(10) // For pay-per-use model

  // Relations
  accounts        Account[]
  sessions        Session[]
  hooks           Hook[]
  scripts         Script[]
  stories         Story[]
  revenue         Revenue[]
  calendar        CalendarEntry[]
  activityLogs    ActivityLog[]
  contentVersions ContentVersion[]
  systemSettings  SystemSetting[]
  contentProgress ContentProgress[]

  // NOCHILL Content OS Relations
  contentCards        ContentCard[]
  hookBank            HookBank[]
  storyBank           StoryBankEntry[]
  icpPainLibrary      ICPPainLibrary[]
  products            Product[]
  contentCalendarPlus ContentCalendarPlus[]
  pipeline            ContentPipeline[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Hook Model
model Hook {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hook content
  content  String
  topic    String
  platform String // instagram, tiktok, youtube, linkedin, twitter
  duration String? // 15s, 30s, 60s, 90s, 3min
  tone     String? // educational, entertaining, inspiring, controversial
  hookType String? // question, statement, story, statistic, challenge

  // Metadata
  category   String? // educate, entertain, encourage, earn
  isFavorite Boolean @default(false)
  likes      Int     @default(0)

  // Performance tracking
  views       Int   @default(0)
  engagement  Float @default(0)
  conversions Int   @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  scripts Script[]

  @@index([userId])
  @@index([platform])
  @@index([category])
  @@map("hooks")
}

// Script Model
model Script {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  hookId String?
  hook   Hook?   @relation(fields: [hookId], references: [id])

  // Script content
  title    String
  content  String // Full script with SEEDS structure
  platform String
  duration String
  goal     String // entertain, educate, encourage, earn

  // Script breakdown (JSON)
  breakdown Json? // Second-by-second breakdown
  visuals   Json? // Visual directions, B-roll suggestions
  overlays  Json? // Text overlays

  // Metadata
  category   String?
  isFavorite Boolean @default(false)

  // Performance tracking
  isPublished Boolean @default(false)
  views       Int     @default(0)
  engagement  Float   @default(0)
  revenue     Float   @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([category])
  @@map("scripts")
}

// Story Model (Proof Stories)
model Story {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Story content
  title     String
  content   String
  storyType String // transformation, achievement, milestone, case_study

  // 4-Criteria Test
  isSpecial      Boolean @default(false)
  isRelevant     Boolean @default(false)
  isQuantifiable Boolean @default(false)
  hasNames       Boolean @default(false)

  // Quantifiable data
  beforeState String?
  afterState  String?
  timeframe   String?
  metrics     Json? // Numbers, percentages, etc.

  // Metadata
  category   String?
  isFavorite Boolean @default(false)

  // Usage tracking
  timesUsed Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([storyType])
  @@map("stories")
}

// Revenue Model (PAIDS Tracking)
model Revenue {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // PAIDS breakdown
  amount      Float
  stream      String // products, ads, info, deals, services
  description String?

  // Date tracking
  month Int // 1-12
  year  Int
  date  DateTime @default(now())

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([stream])
  @@index([year, month])
  @@map("revenue")
}

// Content Calendar Model
model CalendarEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content details
  date        DateTime
  title       String
  description String?
  category    String // educate, entertain, encourage, earn
  platform    String

  // Linked content
  scriptId String?
  hookId   String?

  // Status
  status String @default("planned") // planned, drafted, scheduled, published

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([category])
  @@map("calendar_entries")
}

// Activity Log Model - Track all user actions
model ActivityLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Activity details
  action     String // created, updated, deleted, viewed, exported, generated
  entityType String // hook, script, story, calendar, revenue, user_setting
  entityId   String? // ID of the entity affected

  // Detailed information
  description String? // Human-readable description
  metadata    Json? // Additional data (old values, new values, etc.)

  // Context
  ipAddress String?
  userAgent String?
  sessionId String?

  // Timestamps
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("activity_logs")
}

// Content Version Model - Track content edits and refinements
model ContentVersion {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Version info
  entityType String // hook, script, story
  entityId   String // ID of the content
  version    Int // Version number (1, 2, 3...)

  // Content snapshot
  content Json // Full content snapshot at this version

  // Change tracking
  changeType   String // create, edit, refine, optimize
  changes      Json? // Specific changes made
  changeReason String? // Why was this changed?

  // Metadata
  isActive Boolean @default(false) // Is this the current version?

  // Timestamps
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([isActive])
  @@map("content_versions")
}

// System Settings Model - User preferences for operational system
model SystemSetting {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Settings
  key      String // Setting key (e.g., "auto_backup", "notification_preferences")
  value    Json // Setting value (flexible JSON)
  category String? // Settings category for organization

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("system_settings")
}

// Data Backup Model - Track system backups
model DataBackup {
  id     String  @id @default(cuid())
  userId String? // Optional - can be system-wide backup

  // Backup details
  backupType String // full, incremental, user_data
  fileName   String // Backup file name
  filePath   String? // Storage location
  fileSize   BigInt? // Size in bytes

  // Status
  status String  @default("pending") // pending, completed, failed
  error  String? // Error message if failed

  // Metadata
  dataTypes   Json? // Types of data included (hooks, scripts, stories, etc.)
  recordCount Int? // Number of records backed up

  // Timestamps
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@map("data_backups")
}

// Content Progress Model - Track content through production pipeline
model ContentProgress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content identification
  title       String
  description String?
  contentType String // reel, tiktok, youtube_short, youtube_long, story, carousel, thread
  topic       String?

  // Production stage tracking
  stage    String  @default("ideation") // ideation, scripting, shooting, editing, ready, posted
  substage String? // More granular tracking (e.g., "script_draft", "first_edit", "final_review")

  // Linked content (optional)
  scriptId String?
  hookId   String?
  storyId  String?

  // Platform targeting
  platforms Json // Array of platforms: ["instagram", "tiktok", "youtube"]

  // 4E Content Strategy Tagging
  fourETag String // entertain, educate, encourage, earn

  // Target Audience Awareness Level (R×A×C×U^B - Awareness component)
  awarenessLevel String // symptom_aware, problem_aware, solution_aware, product_aware

  // Clarity Type (Hook outcome type)
  clarityType String? // information_gap, desired_result, undesired_result, a_to_b_transformation

  // Shadow Fear Targeting
  shadowFear String? // invisibility, wasted_potential, left_behind, exposure, etc.

  // Performance tracking URLs and data
  socialUrls  Json? // { "instagram": "url", "tiktok": "url", "youtube": "url" }
  performance Json? // { "instagram": { "views": 0, "engagement": 0 }, ... }

  // Scheduling
  scheduledFor DateTime?
  postedAt     DateTime?

  // Notes and collaboration
  notes String?
  tags  Json? // Custom tags array

  // Status flags
  isPriority Boolean @default(false)
  isArchived Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([stage])
  @@index([fourETag])
  @@index([awarenessLevel])
  @@index([scheduledFor])
  @@index([createdAt])
  @@map("content_progress")
}

// ============================================
// NOCHILL CONTENT OS - COMPREHENSIVE SYSTEM
// ============================================

// Content Card Model - The central hub for each content piece
model ContentCard {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CONTENT IDENTITY
  contentTitle  String
  platform      String // instagram, tiktok, youtube, linkedin, twitter, email
  contentType   String // reel, tiktok, youtube_short, youtube_long, story, carousel, thread, email, blog
  status        String  @default("ideation") // ideation, scripting, shooting, editing, scheduled, published, archived
  contentPillar String // authority, education, monetization, story, conversion
  frameworkUsed String? // PAIDS, DARES, AFRICA Method, 4E, Story Bank, Hook Science

  // ICP TARGETING
  audienceLevel             String // beginner_creator, established_creator, contentpreneur
  icpPainPoint              String // What keeps them awake at night
  shadowFear                String? // family_shame, poverty_cycle, imposter_syndrome, invisibility, etc.
  desiredTransformationFrom String? // Where they are
  desiredTransformationTo   String? // Where they go

  // HOOK ENGINE (R×A×C×U^B)
  hookRelevant   String? // Why this matters to African creators
  hookAwareness  String // symptom_aware, problem_aware, solution_aware, product_aware
  hookClarity    String? // What they will gain
  hookUnique     String? // Pattern interrupt / bold claim
  hookBroadened  String? // More accessible version
  hookVariations Json? // ["Hook 1", "Hook 2", "Hook 3"]

  // SCRIPT STRUCTURE (7-Act Story Arc)
  scriptHook          String? // 0-3s hook
  scriptValuePromise  String? // 3-8s value promise
  scriptFirstConflict String? // First conflict
  scriptBody          String? // Main body content
  scriptRehooks       Json? // ["Rehook 1", "Rehook 2", "Rehook 3"]
  scriptEmotionalPeak String? // Emotional peak
  scriptCTA           String? // Call to action
  scriptRetentionLoop String? // Retention loop
  fullScript          String? // Complete script with all acts

  // STORY BANK CONNECTION
  personalStoryUsed String? // bathroom_floor, losing_followers, brand_deals, sars, mom, aviation, meta_summit
  villain           String? // algorithm_myth, platform_dependency, exploitation, confusion
  proofMoment       String? // Receipt, result, screenshot, testimonial

  // PRODUCT CONNECTION (NOCHILL PTY LTD)
  problemThisSolves   String? // Core problem
  productThatSolvesIt String? // tax_guide, influencers_code, paids_workbook, niche_workbook, skool, coaching, course
  offerLevel          String? // beginner, established, contentpreneur
  productId           String? // Link to Product database
  product             Product? @relation(fields: [productId], references: [id])

  // PRODUCTION SYSTEM
  shootDate           DateTime?
  publishDate         DateTime?
  productionChecklist Json? // {scriptReady, shot, edited, captionWritten, thumbnailReady, scheduled, published}

  // FILMING NOTES
  cameraStyle      String?
  energyLevel      String? // low_intense, conversational, vulnerable, teaching, highest_energy
  location         String?
  bRollIdeas       Json? // ["B-roll idea 1", "B-roll idea 2"]
  visualInterrupts Json? // ["Visual 1", "Visual 2"]

  // PERFORMANCE TRACKING
  views            Int   @default(0)
  comments         Int   @default(0)
  shares           Int   @default(0)
  saves            Int   @default(0)
  watchTime        Float @default(0) // In seconds
  leadsGenerated   Int   @default(0)
  revenueGenerated Float @default(0)

  // LEARNINGS
  lessonLearned String?
  whatWorked    String?
  whatFailed    String?

  // Metadata
  isFavorite Boolean @default(false)
  tags       Json? // Custom tags

  // Relations
  calendarEntries ContentCalendarPlus[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([status])
  @@index([contentPillar])
  @@index([audienceLevel])
  @@index([publishDate])
  @@map("content_cards")
}

// Hooks Bank Model - Repository of all hook variations
model HookBank {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hook Content
  hookText String
  hookType String // question, statement, story, statistic, challenge, pattern_interrupt

  // R×A×C×U^B Components
  relevant       String? // Target audience relevance
  awarenessLevel String // symptom_aware, problem_aware, solution_aware, product_aware
  clarity        String? // Clear outcome promise
  unique         String? // Pattern interrupt element
  broadened      Boolean @default(false) // Is it accessible to wider audience?

  // Categorization
  topic         String?
  contentPillar String? // authority, education, monetization, story, conversion
  platform      String? // Best platform for this hook
  shadowFear    String? // Which Shadow Fear this targets

  // Performance
  timesUsed      Int     @default(0)
  avgPerformance Float   @default(0) // Average views/engagement when used
  isFavorite     Boolean @default(false)

  // Metadata
  tags  Json?
  notes String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([hookType])
  @@index([awarenessLevel])
  @@index([contentPillar])
  @@map("hook_bank")
}

// Story Bank Model - Repository of personal stories (extended from Story model)
model StoryBankEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Story Identity
  storyKey    String // bathroom_floors, r750_to_r100k, instagram_780k_loss, etc.
  title       String
  snippet     String // Short version (5-20 seconds)
  fullVersion String? // Extended version for long-form

  // Story Structure
  timeframe String? // How long to tell (5-8s, 10-12s, 15-18s)
  emotion   String? // Vulnerability → Triumph, Mistake → Mastery
  lesson    String? // Core lesson from the story

  // Use Cases
  useFor         Json // ["Resilience", "Transformation", "Origin story"]
  contentPillars Json? // ["authority", "education", "story"]

  // Numbers & Proof
  beforeState     String?
  afterState      String?
  specificNumbers Json? // {"before": "R750 per post", "after": "R100K per deal"}

  // 4-Criteria Test (Proof Stories)
  isSpecial      Boolean @default(false)
  isRelevant     Boolean @default(false)
  isQuantifiable Boolean @default(false)
  hasNames       Boolean @default(false)

  // Villain & Context
  villain    String? // What/who was the antagonist
  shadowFear String? // Which Shadow Fear this addresses

  // Usage Tracking
  timesUsed Int       @default(0)
  lastUsed  DateTime?
  avgImpact Float     @default(0) // Average performance when included

  // Metadata
  isFavorite Boolean @default(false)
  tags       Json?
  notes      String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([storyKey])
  @@index([isQuantifiable])
  @@map("story_bank")
}

// ICP Pain Library Model - Repository of audience pain points
model ICPPainLibrary {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ICP Definition
  audienceLevel   String // beginner_creator, established_creator, contentpreneur
  audienceSegment String? // More specific (e.g., "African fashion creators")

  // Pain Point
  painPoint     String // What keeps them awake at night
  painCategory  String // financial, visibility, technical, confidence, time, knowledge
  painIntensity String // low, medium, high, critical

  // Shadow Fear Connection
  shadowFear       String? // invisibility, wasted_potential, left_behind, exposure, etc.
  emotionalTrigger String? // Family shame, poverty cycle, imposter syndrome

  // Symptom Manifestation
  symptoms   Json? // How this pain shows up in their life
  objections Json? // Common objections/excuses they make

  // Solution Mapping
  solutionType  String? // education, tool, framework, mindset_shift, system
  productMatch  String? // Which NOCHILL product solves this
  contentPillar String? // Which content pillar addresses this

  // Content Angle
  hookAngles   Json? // Proven hook angles for this pain
  storyMatches Json? // Which stories resonate with this pain

  // Performance
  timesAddressed Int   @default(0)
  avgEngagement  Float @default(0)
  conversionRate Float @default(0)

  // Metadata
  isFavorite Boolean @default(false)
  tags       Json?
  notes      String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([audienceLevel])
  @@index([painCategory])
  @@index([shadowFear])
  @@map("icp_pain_library")
}

// Product Database Model - NOCHILL PTY LTD Product Ecosystem
model Product {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Product Identity
  productName String
  productType String // digital_product, course, coaching, community, service, physical
  price       Float
  currency    String @default("ZAR")

  // Audience Fit
  audienceLevel   String // beginner, established, contentpreneur
  audienceSegment String? // More specific targeting

  // Product Details
  description  String
  coreBenefits String // What they get
  painPoints   String // What problems it solves

  // Sales Elements
  priceAnchor  String? // What they'd pay elsewhere
  bonuses      String? // What's included as bonus
  guarantee    String? // Risk reversal
  testimonials Json? // Social proof

  // PAIDS Classification
  paidsStream String // products, ads, info, deals, services

  // Product Ladder
  ladderPosition String // entry, core, premium, elite
  upsellTo       String? // Next product in ladder
  downsellTo     String? // Lower-tier alternative

  // Performance Tracking
  totalSales     Int   @default(0)
  totalRevenue   Float @default(0)
  conversionRate Float @default(0)
  avgReviewScore Float @default(0)

  // Status
  status     String    @default("active") // active, coming_soon, archived, sold_out
  launchDate DateTime?

  // Metadata
  salesPageUrl   String?
  checkoutUrl    String?
  deliveryMethod String? // email, platform, manual
  isFavorite     Boolean @default(false)
  tags           Json?
  notes          String?

  // Relations
  contentCards ContentCard[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productType])
  @@index([audienceLevel])
  @@index([paidsStream])
  @@index([status])
  @@map("products")
}

// Enhanced Content Calendar Model (extends existing CalendarEntry)
model ContentCalendarPlus {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Scheduling
  scheduledDate DateTime
  publishTime   String? // "09:00", "14:30", etc.
  timezone      String   @default("Africa/Johannesburg")

  // Content Details
  title         String
  description   String?
  contentPillar String // authority, education, monetization, story, conversion
  fourETag      String // educate, entertain, encourage, earn
  platform      String
  contentType   String // reel, tiktok, youtube_short, etc.

  // Links
  contentCardId String? // Link to ContentCard
  contentCard   ContentCard? @relation(fields: [contentCardId], references: [id])
  scriptId      String?
  hookId        String?
  storyId       String?

  // Status
  status        String @default("planned") // planned, drafted, scripting, shooting, editing, scheduled, published, archived
  completionPct Int    @default(0) // 0-100%

  // Campaign/Series Tracking
  campaignName  String?
  seriesName    String?
  episodeNumber Int?

  // Performance Goals
  targetViews      Int?
  targetEngagement Float?
  targetLeads      Int?
  targetRevenue    Float?

  // Metadata
  color            String? // For calendar visualization
  isPriority       Boolean @default(false)
  isRecurring      Boolean @default(false)
  recurringPattern String? // weekly, biweekly, monthly
  tags             Json?
  notes            String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([scheduledDate])
  @@index([status])
  @@index([contentPillar])
  @@index([fourETag])
  @@map("content_calendar_plus")
}

// Content Pipeline — Kanban production tracker
model ContentPipeline {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title          String
  platform       String   @default("instagram")
  icp            String   @default("auto")
  status         String   @default("idea")
  interestPeak   String   @default("")
  hook           String   @default("")
  visualHook     String   @default("")
  value          String   @default("")
  cta            String   @default("")
  rawFootageLink String   @default("")
  scheduledFor   DateTime?
  postedAt       DateTime?

  checkStrong     Boolean  @default(false)
  checkVisual     Boolean  @default(false)
  checkActionable Boolean  @default(false)
  checkWorthy     Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([platform])
  @@map("content_pipeline")
}

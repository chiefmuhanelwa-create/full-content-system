// Prisma Schema for NOCHILL Viral Script Generator

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Subscription info
  plan          String    @default("free") // free, pro, agency
  planExpiry    DateTime?
  credits       Int       @default(10) // For pay-per-use model

  // Relations
  accounts      Account[]
  sessions      Session[]
  hooks         Hook[]
  scripts       Script[]
  stories       Story[]
  revenue       Revenue[]
  calendar      CalendarEntry[]
  activityLogs  ActivityLog[]
  contentVersions ContentVersion[]
  systemSettings SystemSetting[]
  contentProgress ContentProgress[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Hook Model
model Hook {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hook content
  content     String
  topic       String
  platform    String   // instagram, tiktok, youtube, linkedin, twitter
  duration    String?  // 15s, 30s, 60s, 90s, 3min
  tone        String?  // educational, entertaining, inspiring, controversial
  hookType    String?  // question, statement, story, statistic, challenge

  // Metadata
  category    String?  // educate, entertain, encourage, earn
  isFavorite  Boolean  @default(false)
  likes       Int      @default(0)

  // Performance tracking
  views       Int      @default(0)
  engagement  Float    @default(0)
  conversions Int      @default(0)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  scripts     Script[]

  @@index([userId])
  @@index([platform])
  @@index([category])
  @@map("hooks")
}

// Script Model
model Script {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  hookId      String?
  hook        Hook?    @relation(fields: [hookId], references: [id])

  // Script content
  title       String
  content     String   // Full script with SEEDS structure
  platform    String
  duration    String
  goal        String   // entertain, educate, encourage, earn

  // Script breakdown (JSON)
  breakdown   Json?    // Second-by-second breakdown
  visuals     Json?    // Visual directions, B-roll suggestions
  overlays    Json?    // Text overlays

  // Metadata
  category    String?
  isFavorite  Boolean  @default(false)

  // Performance tracking
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  engagement  Float    @default(0)
  revenue     Float    @default(0)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([category])
  @@map("scripts")
}

// Story Model (Proof Stories)
model Story {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Story content
  title       String
  content     String
  storyType   String   // transformation, achievement, milestone, case_study

  // 4-Criteria Test
  isSpecial      Boolean @default(false)
  isRelevant     Boolean @default(false)
  isQuantifiable Boolean @default(false)
  hasNames       Boolean @default(false)

  // Quantifiable data
  beforeState    String?
  afterState     String?
  timeframe      String?
  metrics        Json?   // Numbers, percentages, etc.

  // Metadata
  category       String?
  isFavorite     Boolean @default(false)

  // Usage tracking
  timesUsed      Int     @default(0)

  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([storyType])
  @@map("stories")
}

// Revenue Model (PAIDS Tracking)
model Revenue {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // PAIDS breakdown
  amount      Float
  stream      String   // products, ads, info, deals, services
  description String?

  // Date tracking
  month       Int      // 1-12
  year        Int
  date        DateTime @default(now())

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([stream])
  @@index([year, month])
  @@map("revenue")
}

// Content Calendar Model
model CalendarEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content details
  date        DateTime
  title       String
  description String?
  category    String   // educate, entertain, encourage, earn
  platform    String

  // Linked content
  scriptId    String?
  hookId      String?

  // Status
  status      String   @default("planned") // planned, drafted, scheduled, published

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([category])
  @@map("calendar_entries")
}

// Activity Log Model - Track all user actions
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Activity details
  action      String   // created, updated, deleted, viewed, exported, generated
  entityType  String   // hook, script, story, calendar, revenue, user_setting
  entityId    String?  // ID of the entity affected

  // Detailed information
  description String?  // Human-readable description
  metadata    Json?    // Additional data (old values, new values, etc.)

  // Context
  ipAddress   String?
  userAgent   String?
  sessionId   String?

  // Timestamps
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("activity_logs")
}

// Content Version Model - Track content edits and refinements
model ContentVersion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Version info
  entityType  String   // hook, script, story
  entityId    String   // ID of the content
  version     Int      // Version number (1, 2, 3...)

  // Content snapshot
  content     Json     // Full content snapshot at this version

  // Change tracking
  changeType  String   // create, edit, refine, optimize
  changes     Json?    // Specific changes made
  changeReason String? // Why was this changed?

  // Metadata
  isActive    Boolean  @default(false) // Is this the current version?

  // Timestamps
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([isActive])
  @@map("content_versions")
}

// System Settings Model - User preferences for operational system
model SystemSetting {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Settings
  key         String   // Setting key (e.g., "auto_backup", "notification_preferences")
  value       Json     // Setting value (flexible JSON)
  category    String?  // Settings category for organization

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("system_settings")
}

// Data Backup Model - Track system backups
model DataBackup {
  id          String   @id @default(cuid())
  userId      String?  // Optional - can be system-wide backup

  // Backup details
  backupType  String   // full, incremental, user_data
  fileName    String   // Backup file name
  filePath    String?  // Storage location
  fileSize    BigInt?  // Size in bytes

  // Status
  status      String   @default("pending") // pending, completed, failed
  error       String?  // Error message if failed

  // Metadata
  dataTypes   Json?    // Types of data included (hooks, scripts, stories, etc.)
  recordCount Int?     // Number of records backed up

  // Timestamps
  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@map("data_backups")
}

// Content Progress Model - Track content through production pipeline
model ContentProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content identification
  title       String
  description String?
  contentType String   // reel, tiktok, youtube_short, youtube_long, story, carousel, thread
  topic       String?

  // Production stage tracking
  stage       String   @default("ideation") // ideation, scripting, shooting, editing, ready, posted
  substage    String?  // More granular tracking (e.g., "script_draft", "first_edit", "final_review")

  // Linked content (optional)
  scriptId    String?
  hookId      String?
  storyId     String?

  // Platform targeting
  platforms   Json     // Array of platforms: ["instagram", "tiktok", "youtube"]

  // 4E Content Strategy Tagging
  fourETag    String   // entertain, educate, encourage, earn

  // Target Audience Awareness Level (R×A×C×U^B - Awareness component)
  awarenessLevel String // symptom_aware, problem_aware, solution_aware, product_aware

  // Clarity Type (Hook outcome type)
  clarityType String?  // information_gap, desired_result, undesired_result, a_to_b_transformation

  // Shadow Fear Targeting
  shadowFear  String?  // invisibility, wasted_potential, left_behind, exposure, etc.

  // Performance tracking URLs and data
  socialUrls  Json?    // { "instagram": "url", "tiktok": "url", "youtube": "url" }
  performance Json?    // { "instagram": { "views": 0, "engagement": 0 }, ... }

  // Scheduling
  scheduledFor DateTime?
  postedAt     DateTime?

  // Notes and collaboration
  notes       String?
  tags        Json?    // Custom tags array

  // Status flags
  isPriority  Boolean  @default(false)
  isArchived  Boolean  @default(false)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([stage])
  @@index([fourETag])
  @@index([awarenessLevel])
  @@index([scheduledFor])
  @@index([createdAt])
  @@map("content_progress")
}

// Prisma Schema for NOCHILL Viral Script Generator

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Subscription info
  plan          String    @default("free") // free, pro, agency
  planExpiry    DateTime?
  credits       Int       @default(10) // For pay-per-use model

  // Relations
  accounts      Account[]
  sessions      Session[]
  hooks         Hook[]
  scripts       Script[]
  stories       Story[]
  revenue       Revenue[]
  calendar      CalendarEntry[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Hook Model
model Hook {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hook content
  content     String
  topic       String
  platform    String   // instagram, tiktok, youtube, linkedin, twitter
  duration    String?  // 15s, 30s, 60s, 90s, 3min
  tone        String?  // educational, entertaining, inspiring, controversial
  hookType    String?  // question, statement, story, statistic, challenge

  // Metadata
  category    String?  // educate, entertain, encourage, earn
  isFavorite  Boolean  @default(false)
  likes       Int      @default(0)

  // Performance tracking
  views       Int      @default(0)
  engagement  Float    @default(0)
  conversions Int      @default(0)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  scripts     Script[]

  @@index([userId])
  @@index([platform])
  @@index([category])
  @@map("hooks")
}

// Script Model
model Script {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  hookId      String?
  hook        Hook?    @relation(fields: [hookId], references: [id])

  // Script content
  title       String
  content     String   // Full script with SEEDS structure
  platform    String
  duration    String
  goal        String   // entertain, educate, encourage, earn

  // Script breakdown (JSON)
  breakdown   Json?    // Second-by-second breakdown
  visuals     Json?    // Visual directions, B-roll suggestions
  overlays    Json?    // Text overlays

  // Metadata
  category    String?
  isFavorite  Boolean  @default(false)

  // Performance tracking
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  engagement  Float    @default(0)
  revenue     Float    @default(0)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([category])
  @@map("scripts")
}

// Story Model (Proof Stories)
model Story {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Story content
  title       String
  content     String
  storyType   String   // transformation, achievement, milestone, case_study

  // 4-Criteria Test
  isSpecial      Boolean @default(false)
  isRelevant     Boolean @default(false)
  isQuantifiable Boolean @default(false)
  hasNames       Boolean @default(false)

  // Quantifiable data
  beforeState    String?
  afterState     String?
  timeframe      String?
  metrics        Json?   // Numbers, percentages, etc.

  // Metadata
  category       String?
  isFavorite     Boolean @default(false)

  // Usage tracking
  timesUsed      Int     @default(0)

  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([storyType])
  @@map("stories")
}

// Revenue Model (PAIDS Tracking)
model Revenue {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // PAIDS breakdown
  amount      Float
  stream      String   // products, ads, info, deals, services
  description String?

  // Date tracking
  month       Int      // 1-12
  year        Int
  date        DateTime @default(now())

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([stream])
  @@index([year, month])
  @@map("revenue")
}

// Content Calendar Model
model CalendarEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content details
  date        DateTime
  title       String
  description String?
  category    String   // educate, entertain, encourage, earn
  platform    String

  // Linked content
  scriptId    String?
  hookId      String?

  // Status
  status      String   @default("planned") // planned, drafted, scheduled, published

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([category])
  @@map("calendar_entries")
}
